# Supabase 랭킹 연동용 환경변수
# 기존에 쓰던 Supabase 프로젝트 중 하나의 값을 그대로 넣으면 됩니다.
# 콘솔 > Project Settings > API 에서 확인
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi... (anon public key)

# 리워드 광고(IAA) 그룹 ID
#  - 비워두면 토스 공식 "보상형 테스트 ID"(ait-ad-test-rewarded-id)로 동작해요.
#  - 출시 시 앱인토스 콘솔에서 광고 그룹을 만들어 발급된 운영 ID로 교체하세요.
#  - ⚠️ 개발/테스트 중엔 절대 운영 ID를 쓰지 마세요 (제재 대상).
VITE_AD_GROUP_ID=
